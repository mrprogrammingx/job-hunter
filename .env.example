ANTHROPIC_API_KEY=your_api_key_here

# Database — SQLite (default, no setup needed)
DATABASE_URL=sqlite+aiosqlite:///data/jobs.db

# Database — PostgreSQL (uncomment to use with docker-compose)
# DATABASE_URL=postgresql+asyncpg://jobhunter:jobhunter@localhost:5432/jobhunter

# OpenTelemetry — set to true and run: docker-compose up jaeger
OTEL_ENABLED=false
OTEL_ENDPOINT=http://localhost:4317

# Backend port (8001 avoids conflict with other local services on 8000)
BACKEND_PORT=8001

# Frontend allowed origins
CORS_ORIGINS=["http://localhost:3000"]
